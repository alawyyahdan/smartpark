VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public URL of the deployed web app (used to build QR-code links)
# In production this MUST be set to your real domain or QR codes will be broken.
VITE_APP_URL=http://localhost:5173

# Path to admin panel (defaults to /admin). Override to obscure the admin route.
VITE_ADMIN_PATH=/admin

# Service Keys for mqtt-bridge (Background Worker)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# MQTT broker keepalive in seconds (mqtt-bridge only)
MQTT_KEEPALIVE=30
